{
    "name": "graphical-editor-monorepo",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev:demo": "pnpm --dir demo dev",
        "build:core": "pnpm --filter @graphical-editor/core build",
        "build:demo": "pnpm --dir demo build",
        "dev": "pnpm dev:demo",
        "build": "pnpm build:core && pnpm build:demo"
    },
    "dependencies": {
        "@primeuix/utils": "latest",
        "pinia": "^3.0.4",
        "pixi-viewport": "latest",
        "pixi.js": "latest",
        "primevue": "latest",
        "vue": "^3.4.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "typescript": "^5.0.0",
        "vite": "^5.0.0",
        "vue-tsc": "^2.0.0"
    }
}