{
  "name": "graphical-editor-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:demo": "pnpm --dir demo dev",
    "build:core": "pnpm --filter @graphical-editor/core build",
    "build:demo": "pnpm --dir demo build",
    "dev": "pnpm dev:demo",
    "build": "pnpm build:core && pnpm build:demo"
  }
}
